# Local dev: copy values into next-console/.env (or .env.local).
# 1) pnpm docker:db   (starts Postgres from docker/dev/docker-compose.yaml)
# 2) pnpm db:migrate  (creates DB if missing, then Better Auth schema)
# If ``next_console`` was never created (old volume), ``db:ensure`` fixes it.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/next_console

# Backend API URL (defaults to http://localhost:8088 if not set)
NEXT_PUBLIC_API_URL=http://localhost:8088

# ──────────────────────────────────────────────────────────────────────────────
# Wisecore 生产环境配置示例
#
# 复制此文件为 .env.prod 并修改配置
# 启动: docker compose -f docker/docker-compose.yaml --env-file .env.prod up -d
# ──────────────────────────────────────────────────────────────────────────────

# ── 镜像配置 ──────────────────────────────────────────────────────────────────

# Docker 镜像仓库 (可选，如 repo.example.com/docker-public)
DOCKER_REGISTRY=

# API 镜像标签 (完整镜像名，如 wisecore:v1.0.0 或 repo.example.com/wisecore:v1.0.0)
IMAGE_TAG=wisecore:v1.0.0

# 前端镜像标签
NEXT_IMAGE_TAG=wisecore-console:v1.0.0

# ── 端口配置 ──────────────────────────────────────────────────────────────────

# 后端 API 端口
PORT=8088

# 前端端口
NEXT_PORT=3000

# PostgreSQL 端口
POSTGRES_PORT=5432

# ── 数据库配置 ────────────────────────────────────────────────────────────────

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=next_console

# ── LLM 提供商配置 (可选) ────────────────────────────────────────────────────

# OpenAI
# OPENAI_API_KEY=sk-xxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# Google AI
# GOOGLE_API_KEY=xxx

# ── Keycloak SSO 配置 (可选) ─────────────────────────────────────────────────

# KEYCLOAK_ISSUER=https://keycloak.example.com/realms/your-realm
# KEYCLOAK_AUDIENCE=your-client-id
# KEYCLOAK_JWKS_URL=https://keycloak.example.com/realms/your-realm/protocol/openid-connect/certs

# ── 其他配置 ──────────────────────────────────────────────────────────────────

# 时区
TZ=Asia/Shanghai

# 日志级别
LOG_LEVEL=info